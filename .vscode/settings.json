{
    "code-runner.executorMap": {
        "python": "cd $dir && $pythonPath $fullFileName"
    },
    "python.analysis.diagnosticSeverityOverrides": {
        "reportInvalidTypeForm": "none"
    },
    "files.exclude": {
        ".direnv": true,
        ".venv": true,
        "src/__pycache__": true,
        "src/spiders/__pycache__": true,
        ".envrc": true,
        "flake.lock": true,
        "poetry.lock": true,
        ".vscode": true,
        ".devcontainer": true,
        ".replit": true,
        "replit.nix": true,
        "repl.deploy": true,
        "replit-deploy.json": true
    }
}