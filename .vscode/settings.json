{
    "code-runner.executorMap": {
        "python": "cd $dir && $pythonPath $fullFileName"
    },
    "python.analysis.diagnosticSeverityOverrides": {
        "reportInvalidTypeForm": "none"
    },
    "files.exclude": {
        ".direnv": false,
        ".venv": false,
        "src/__pycache__": false,
        "src/spiders/__pycache__": false,
        ".envrc": false,
        "flake.lock": false,
        "poetry.lock": false,
        ".vscode": false,
        ".devcontainer": false,
        ".replit": false,
        "replit.nix": false,
    }
}