run = "bash run.sh"
entrypoint = "src/__init__.py"
modules = ["python-3.10:v18-20230807-322e88b"]
hidden = ["flake.nix", "flake.lock", "repl.deploy", "replit-deploy.json"]

[nix]
channel = "stable-23_05"

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = "./repl.deploy --standalone python3 src/__init__.py"
deploymentTarget = "gce"
ignorePorts = true
